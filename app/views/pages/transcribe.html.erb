<!DOCTYPE html>
<html>
<head>
  <title>Voice Transcription & Summary</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

  <style>
    body { font-family: sans-serif; background: #f9f9f9; }
    .container { max-width: 900px; margin: 40px auto; padding: 24px; background: white; border-radius: 8px; box-shadow: 0 2px 14px rgba(0,0,0,0.08); }
    .transcription-box { min-height: 80px; border: 1px solid #ddd; padding: 12px; white-space: pre-wrap; border-radius: 6px; margin-bottom: 12px; }
    .controls { margin-bottom: 12px; }
    button { cursor: pointer; padding: 10px 18px; margin-right: 10px; border: none; border-radius: 6px; font-size: 15px; }
    #startBtn { background: #22c55e; color: white; }
    #stopBtn { background: #ef4444; color: white; }
  </style>
</head>
<body>
<div class="container">
  <h1>Voice Transcription & Summary</h1>

  <div class="controls">
    <button id="startBtn">Start Recording</button>
    <button id="stopBtn" disabled>Stop & Send</button>
  </div>

  <h3>Live / Final Transcription</h3>
  <pre id="finalText" class="transcription-box"></pre>

  <h3>Summary</h3>
  <pre id="summaryText" class="transcription-box"></pre>

  <h3>Playback</h3>
  <audio id="audioPlayback" controls></audio>
</div>

<script>
  // Use global ActionCable consumer (Rails provides it in default layout/application.js)
  const consumer = (window.ActionCable && window.ActionCable.createConsumer && window.ActionCable.createConsumer()) || null;

  document.addEventListener('DOMContentLoaded', function() {
    const startBtn = document.getElementById('startBtn');
    const stopBtn = document.getElementById('stopBtn');
    const finalText = document.getElementById('finalText');
    const summaryText = document.getElementById('summaryText');
    const audioPlayback = document.getElementById('audioPlayback');

    let mediaRecorder = null;
    let audioChunks = [];
    let subscription = null;
    let transcriptionId = null;

    startBtn.onclick = async function() {
      startBtn.disabled = true;
      stopBtn.disabled = false;
      finalText.innerText = '';
      summaryText.innerText = '';
      audioPlayback.src = '';
      audioChunks = [];

      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        mediaRecorder = new MediaRecorder(stream);

        mediaRecorder.ondataavailable = (e) => {
          if (e.data && e.data.size > 0) audioChunks.push(e.data);
        };

        mediaRecorder.start();
        console.log("Recording started");
      } catch (err) {
        alert("Microphone access error: " + err.message);
        startBtn.disabled = false;
        stopBtn.disabled = true;
      }
    };

    stopBtn.onclick = async function() {
      stopBtn.disabled = true;
      startBtn.disabled = false;

      if (!mediaRecorder) return;

      await new Promise(resolve => {
        mediaRecorder.onstop = resolve;
        if (mediaRecorder.state !== 'inactive') mediaRecorder.stop();
      });

      if (audioChunks.length === 0) {
        alert("No audio captured");
        return;
      }

      const blob = new Blob(audioChunks, { type: 'audio/webm' });
      audioPlayback.src = URL.createObjectURL(blob);

      // Build FormData
      const formData = new FormData();
      formData.append('audio', blob, 'recording.webm');

      // CSRF token header if present
      const tokenEl = document.querySelector('meta[name="csrf-token"]');
      const headers = tokenEl ? { 'X-CSRF-Token': tokenEl.content } : {};

      finalText.innerText = "Uploading audio...";
      try {
        const res = await fetch('/transcriptions', { method: 'POST', body: formData, headers });
        if (!res.ok) {
          const text = await res.text();
          finalText.innerText = `Upload failed: ${res.status} ${text}`;
          return;
        }

        const body = await res.json();
        transcriptionId = body.id;
        finalText.innerText = "Audio uploaded — waiting for transcription...";

        // subscribe to ActionCable updates for this transcription
        if (consumer && transcriptionId) {
          if (subscription) subscription.unsubscribe();

          subscription = consumer.subscriptions.create(
            { channel: "TranscriptionChannel", id: transcriptionId },
            {
              connected() { console.log("AC connected for", transcriptionId); },
              received(data) {
                console.log("AC received", data);
                if (data.final_transcription) finalText.innerText = data.final_transcription;
                if (data.summary) summaryText.innerText = data.summary;
                if (data.status && data.status === "error") finalText.innerText = "Error: " + (data.error || "unknown");
              }
            }
          );
        } else {
          // If ActionCable isn't available (rare), poll the summary endpoint
          pollSummary(transcriptionId);
        }
      } catch (err) {
        finalText.innerText = "Network error: " + err.message;
      }
    };

    async function pollSummary(id, attempts = 0) {
      try {
        const r = await fetch('/summary/' + id);
        const j = await r.json();
        if (j.status === 'done') {
          finalText.innerText = j.transcription || finalText.innerText;
          summaryText.innerText = j.summary || '';
        } else if (attempts < 20) {
          setTimeout(() => pollSummary(id, attempts + 1), 2000);
        } else {
          summaryText.innerText = "Summary not ready yet.";
        }
      } catch (e) {
        console.error("Poll error", e);
      }
    }
  });
</script>
</body>
</html>
